<UserControl x:Class="WinClean.Views.LargeFileScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinClean.Converters"
             xmlns:lang="clr-namespace:WinClean.Localization">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
        <converters:DiskUsagePercentToBrushConverter x:Key="DiskUsageBrushConverter" />
        <converters:PercentageToWidthConverter x:Key="PercentToWidth" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{lang:Lang LF_Title}" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{lang:Lang LF_Desc}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Drives}"
                      SelectedItem="{Binding SelectedDrive}"
                      DisplayMemberPath="Name"
                      materialDesign:HintAssist.Hint="{lang:Lang LF_SelectDisk}"
                      Style="{StaticResource MaterialDesignComboBox}"
                      Margin="0,0,8,0" />

            <Button Grid.Column="1" Content="{lang:Lang LF_Browse}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding BrowseFolderCommand}"
                    Margin="0,0,8,0" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <TextBlock Text="{lang:Lang LF_MinSize}" VerticalAlignment="Center" />
                <TextBox Text="{Binding MinSizeMB, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="MB" />
                <TextBlock Text=" MB" VerticalAlignment="Center" />
            </StackPanel>

            <Button Grid.Column="3"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Command="{Binding ScanCommand}" Padding="24,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{lang:Lang LF_Scan}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Results -->
        <materialDesign:Card Grid.Row="2" Padding="0"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <DataGrid x:Name="FilesGrid"
                          ItemsSource="{Binding Files}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          MouseDoubleClick="FilesGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding FileName}" MinWidth="200" Width="Auto">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [LF_ColFileName], Source={x:Static lang:LangProvider.Instance}}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="100" SortDirection="Descending">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [LF_ColSize], Source={x:Static lang:LangProvider.Instance}}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding Extension}" Width="80">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [LF_ColType], Source={x:Static lang:LangProvider.Instance}}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding LastModified, StringFormat=yyyy-MM-dd}" Width="110">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [LF_ColModDate], Source={x:Static lang:LangProvider.Instance}}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding Directory}" MinWidth="300" Width="Auto">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding [LF_ColPath], Source={x:Static lang:LangProvider.Instance}}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{lang:Lang LF_CtxOpenFolder}" Click="OpenInExplorer_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="FolderOpen" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{lang:Lang LF_CtxRecycleBin}" Click="DeleteToRecycleBin_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="DeleteCircle" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{lang:Lang LF_CtxPermanentDelete}" Click="PermanentDelete_Click" Foreground="Red">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="DeleteForever" Foreground="Red" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- Scanning Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Margin="0,0,0,12" />
                        <TextBlock Text="{lang:Lang LF_Scanning}" Foreground="White"
                                   HorizontalAlignment="Center" FontSize="14" />
                        <TextBlock Text="{Binding CurrentScanPath}" Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Center" FontSize="11"
                                   TextTrimming="CharacterEllipsis" MaxWidth="400" Margin="0,4,0,8" />
                        <Button Content="{lang:Lang LF_Cancel}" Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="White" BorderBrush="White"
                                Width="120" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,12,0,0"
              Visibility="{Binding HasDiskInfo, Converter={StaticResource BoolToVisConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding DiskDriveName}" FontWeight="Bold"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" />

                <Grid Grid.Column="1" Height="14" VerticalAlignment="Center">
                    <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            CornerRadius="7" BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                            BorderThickness="1" />
                    <Border CornerRadius="7" HorizontalAlignment="Left"
                            Background="{Binding DiskUsedPercent, Converter={StaticResource DiskUsageBrushConverter}}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource PercentToWidth}">
                                <Binding Path="DiskUsedPercent" />
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}" />
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Grid>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                           FontSize="12" Opacity="0.7">
                    <Run Text="{Binding DiskUsedPercent, StringFormat={}{0:F1}%, Mode=OneWay}" />
                </TextBlock>
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding DiskInfoText}" FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{Binding DiskUsedPercent, Converter={StaticResource DiskUsageBrushConverter}}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{lang:Lang LF_TotalPrefix}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ResultCount}" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="{lang:Lang LF_FilesSuffix}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalSizeText}" FontWeight="Bold" VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
