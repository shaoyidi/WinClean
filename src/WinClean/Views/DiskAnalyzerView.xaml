<UserControl x:Class="WinClean.Views.DiskAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinClean.Converters"
             xmlns:lang="clr-namespace:WinClean.Localization">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{lang:Lang DA_Title}" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{lang:Lang DA_Desc}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding Drives}"
                      SelectedItem="{Binding SelectedDrive}"
                      DisplayMemberPath="Name"
                      materialDesign:HintAssist.Hint="{lang:Lang DA_SelectDisk}"
                      Style="{StaticResource MaterialDesignComboBox}"
                      Margin="0,0,8,0" />

            <Button Grid.Column="1" Content="{lang:Lang DA_Browse}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding BrowseFolderCommand}"
                    Margin="0,0,8,0" />

            <Button Grid.Column="2"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Command="{Binding AnalyzeCommand}" Padding="24,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ChartDonut" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{lang:Lang DA_Analyze}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Tree View -->
        <materialDesign:Card Grid.Row="2" Padding="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <TreeView ItemsSource="{Binding RootNodes}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="4,6" MinWidth="500">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <materialDesign:PackIcon Grid.Column="0" Kind="Folder"
                                                         Width="20" Height="20" VerticalAlignment="Center"
                                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                         Margin="0,0,8,0" />

                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           VerticalAlignment="Center" FontSize="13"
                                           TextTrimming="CharacterEllipsis" />

                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                    <ProgressBar Value="{Binding Percentage}" Minimum="0" Maximum="100"
                                                 Height="8" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                </Grid>

                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           TextAlignment="Right" FontWeight="Medium"
                                           Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" />

                                <Button Grid.Column="4" ToolTip="{lang:Lang DA_OpenInExplorer}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        Width="28" Height="28"
                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="16" Height="16" />
                                </Button>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- Scanning Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Margin="0,0,0,12" />
                        <TextBlock Text="{lang:Lang DA_Analyzing}" Foreground="White"
                                   HorizontalAlignment="Center" FontSize="14" />
                        <TextBlock Text="{Binding CurrentScanPath}" Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Center" FontSize="11"
                                   TextTrimming="CharacterEllipsis" MaxWidth="400" Margin="0,4,0,8" />
                        <Button Content="{lang:Lang DA_Cancel}" Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="White" BorderBrush="White"
                                Width="120" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Margin="0,12,0,0" FontSize="13" />
    </Grid>
</UserControl>
