<UserControl x:Class="WinClean.Views.SystemCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinClean.Converters"
             xmlns:lang="clr-namespace:WinClean.Localization">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{lang:Lang SC_Title}" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{lang:Lang SC_Desc}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Clean Items List -->
        <materialDesign:Card Grid.Row="1" Padding="0" Margin="0,0,0,16"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <ListView ItemsSource="{Binding CleanItems}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                      VerticalAlignment="Center" Margin="0,0,8,0" />

                            <materialDesign:PackIcon Grid.Column="1" Kind="{Binding IconKind}"
                                                     Width="28" Height="28" VerticalAlignment="Center"
                                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                                     Margin="0,0,12,0"/>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="14" />
                                <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="12" />
                            </StackPanel>

                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="8,0"
                                       Opacity="0.6" FontSize="12">
                                <Run Text="{Binding FileCount, Mode=OneWay}" />
                                <Run Text="{Binding [SC_Files], Source={x:Static lang:LangProvider.Instance}, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                       FontWeight="Bold" MinWidth="80" TextAlignment="Right"
                                       Text="{Binding Size, Converter={StaticResource FileSizeConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </materialDesign:Card>

        <!-- Scanning status -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"
                         Margin="0,0,0,8" />
            <TextBlock Text="{Binding CurrentScanPath}" Opacity="0.5" FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}" />
            <TextBlock Text="{Binding StatusText}" FontSize="13" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Action Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="12,8"
                                 Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{lang:Lang SC_FreeableSpace}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TotalSizeText}" FontWeight="Bold" FontSize="16"
                               VerticalAlignment="Center" />
                </StackPanel>
            </materialDesign:Card>

            <Button Grid.Column="3" Content="{lang:Lang SC_SelectAll}" Margin="8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding SelectAllCommand}" />

            <Button Grid.Column="4" Content="{lang:Lang SC_Scan}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"
                    Margin="8,0" Padding="24,8" />

            <Button Grid.Column="5" Content="{lang:Lang SC_Clean}"
                    Style="{StaticResource DangerRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Command="{Binding CleanCommand}"
                    Padding="24,8" />
        </Grid>
    </Grid>
</UserControl>
