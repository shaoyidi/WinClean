<Window x:Class="WinClean.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:WinClean.ViewModels"
        xmlns:views="clr-namespace:WinClean.Views"
        xmlns:lang="clr-namespace:WinClean.Localization"
        mc:Ignorable="d"
        Title="{lang:Lang App_Title}"
        Height="720" Width="1080"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Icon="pack://application:,,,/Resources/app.ico"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Yu Gothic UI, Malgun Gothic">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:SystemCleanerViewModel}">
            <views:SystemCleanerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LargeFileScannerViewModel}">
            <views:LargeFileScannerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DuplicateFinderViewModel}">
            <views:DuplicateFinderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiskAnalyzerViewModel}">
            <views:DiskAnalyzerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Window control button style -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="40" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#30FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#B3000F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0"
                  Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/app.ico"
                           Width="18" Height="18" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="WinClean" FontSize="13" FontWeight="Medium"
                               VerticalAlignment="Center" Opacity="0.85" />
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeClick">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="MaximizeClick">
                        <materialDesign:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="16" Height="16" />
                    </Button>
                    <Button Style="{StaticResource TitleBarCloseButton}" Click="CloseClick">
                        <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Navigation -->
                <Border Grid.Column="0"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                        BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- App Header -->
                        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,10">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/Resources/app.ico"
                                       Width="32" Height="32" Margin="0,0,10,0"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="WinClean"
                                               FontSize="22" FontWeight="Bold"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                                    <TextBlock Text="{lang:Lang App_Subtitle}"
                                               FontSize="11" Opacity="0.6" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Separator DockPanel.Dock="Top" Margin="16,0" />

                        <!-- Navigation Items -->
                        <ListBox x:Name="NavList"
                                 SelectedIndex="{Binding SelectedNavIndex}"
                                 Margin="8,8,8,8"
                                 Style="{StaticResource MaterialDesignNavigationListBox}">
                            <ListBoxItem Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Broom" Width="24" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{lang:Lang Nav_SystemCleaner}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileSearch" Width="24" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{lang:Lang Nav_LargeFileScanner}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentDuplicate" Width="24" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{lang:Lang Nav_DuplicateFinder}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartDonut" Width="24" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{lang:Lang Nav_DiskAnalyzer}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </ListBoxItem>
                            <ListBoxItem Padding="12,12">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{lang:Lang Nav_Settings}" Margin="16,0,0,0" VerticalAlignment="Center" FontSize="14" />
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Content Area -->
                <ContentControl Grid.Column="1"
                                Content="{Binding CurrentView}"
                                Margin="0" />
            </Grid>
        </Grid>
    </Border>
</Window>
