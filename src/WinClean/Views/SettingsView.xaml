<UserControl x:Class="WinClean.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinClean.Converters"
             xmlns:lang="clr-namespace:WinClean.Localization"
             xmlns:vm="clr-namespace:WinClean.ViewModels">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="600">
            <!-- Header -->
            <TextBlock Text="{lang:Lang ST_Title}" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />

            <!-- Appearance -->
            <TextBlock Text="{lang:Lang ST_Appearance}" FontSize="16" FontWeight="Medium"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,12" />

            <materialDesign:Card Padding="16" Margin="0,0,0,8"
                                 materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{lang:Lang ST_DarkTheme}" FontSize="14" />
                            <TextBlock Text="{lang:Lang ST_DarkThemeDesc}" Opacity="0.6" FontSize="12" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding IsDarkTheme}" />
                    </Grid>

                    <Separator Margin="0,0,0,16" />

                    <!-- Language -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{lang:Lang ST_Language}" FontSize="14" />
                            <TextBlock Text="{lang:Lang ST_LanguageDesc}" Opacity="0.6" FontSize="12" />
                        </StackPanel>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="160"
                                  Style="{StaticResource MaterialDesignComboBox}" />
                    </Grid>

                    <Separator Margin="0,0,0,16" />

                    <!-- Theme Color -->
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="{lang:Lang ST_ThemeColor}" FontSize="14" />
                        <TextBlock Text="{lang:Lang ST_ThemeColorDesc}" Opacity="0.6" FontSize="12" Margin="0,0,0,10" />

                        <ListBox ItemsSource="{x:Static vm:SettingsViewModel.AvailableColors}"
                                 SelectedItem="{Binding SelectedColor}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid Width="36" Height="36" Margin="2" Cursor="Hand"
                                                      ToolTip="{Binding Name}">
                                                    <Ellipse x:Name="ColorDot" Width="28" Height="28">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{Binding Hex}" />
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse x:Name="Ring" Width="34" Height="34"
                                                             StrokeThickness="2" Fill="Transparent"
                                                             Visibility="Collapsed">
                                                        <Ellipse.Stroke>
                                                            <SolidColorBrush Color="{Binding Hex}" />
                                                        </Ellipse.Stroke>
                                                    </Ellipse>
                                                    <materialDesign:PackIcon x:Name="Check"
                                                        Kind="Check" Width="16" Height="16"
                                                        Foreground="White"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Visibility="Collapsed" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Ring" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ColorDot" Property="Width" Value="30" />
                                                        <Setter TargetName="ColorDot" Property="Height" Value="30" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Behavior -->
            <TextBlock Text="{lang:Lang ST_Behavior}" FontSize="16" FontWeight="Medium"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,16,0,12" />

            <materialDesign:Card Padding="16" Margin="0,0,0,8"
                                 materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{lang:Lang ST_DeleteToRecycleBin}" FontSize="14" />
                            <TextBlock Text="{lang:Lang ST_DeleteToRecycleBinDesc}" Opacity="0.6" FontSize="12" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding DeleteToRecycleBin}" />
                    </Grid>

                    <Separator Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{lang:Lang ST_ConfirmBeforeDelete}" FontSize="14" />
                            <TextBlock Text="{lang:Lang ST_ConfirmBeforeDeleteDesc}" Opacity="0.6" FontSize="12" />
                        </StackPanel>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                      IsChecked="{Binding ConfirmBeforeDelete}" />
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- Admin -->
            <TextBlock Text="{lang:Lang ST_Permission}" FontSize="16" FontWeight="Medium"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,16,0,12" />

            <materialDesign:Card Padding="16" Margin="0,0,0,24"
                                 materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{lang:Lang ST_AdminPermission}" FontSize="14" />
                            <materialDesign:Chip Content="{lang:Lang ST_AdminAcquired}" Margin="8,0,0,0"
                                                 Foreground="Green"
                                                 Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConverter}}" />
                        </StackPanel>
                        <TextBlock Text="{lang:Lang ST_AdminDesc}" Opacity="0.6" FontSize="12" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="{lang:Lang ST_RestartAsAdmin}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding RestartAsAdminCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}" />
                </Grid>
            </materialDesign:Card>

            <!-- About -->
            <TextBlock Text="{lang:Lang ST_About}" FontSize="16" FontWeight="Medium"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,0,12" />

            <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel>
                    <TextBlock Text="WinClean" FontSize="18" FontWeight="Bold" />
                    <TextBlock Margin="0,4,0,0" Opacity="0.6">
                        <Run Text="{Binding [ST_Version], Source={x:Static lang:LangProvider.Instance}, Mode=OneWay}" />
                        <Run Text="{Binding AppVersion, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{lang:Lang ST_AboutDesc}" Opacity="0.6" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
