<UserControl x:Class="WinClean.Views.DuplicateFinderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:WinClean.Converters"
             xmlns:lang="clr-namespace:WinClean.Localization">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{lang:Lang DF_Title}" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{lang:Lang DF_Desc}" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Selection Area -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding AddFolderCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0" Padding="16,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderPlus" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{lang:Lang DF_SelectFolders}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="DrivePopupAnchor"
                            Command="{Binding OpenDrivePopupCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Harddisk" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{lang:Lang DF_SelectDrives}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Popup IsOpen="{Binding IsDrivePopupOpen}" StaysOpen="False"
                           PlacementTarget="{Binding ElementName=DrivePopupAnchor}"
                           Placement="Bottom" HorizontalOffset="0" VerticalOffset="4"
                           AllowsTransparency="True" PopupAnimation="Fade">
                        <materialDesign:Card Padding="16" Margin="4"
                                             materialDesign:ElevationAssist.Elevation="Dp4"
                                             MinWidth="300">
                            <StackPanel>
                                <TextBlock Text="{lang:Lang DF_SelectDrivesTitle}" FontWeight="Medium" Margin="0,0,0,10" />
                                <ItemsControl ItemsSource="{Binding AvailableDrives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked}" Content="{Binding DisplayName}"
                                                      Margin="0,4" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="{lang:Lang DF_Confirm}" Margin="0,12,0,0"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="4"
                                        Command="{Binding ConfirmDriveSelectionCommand}"
                                        HorizontalAlignment="Right" Padding="24,4" />
                            </StackPanel>
                        </materialDesign:Card>
                    </Popup>
                </StackPanel>

                <Button Grid.Column="3"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Command="{Binding ScanCommand}" Padding="24,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{lang:Lang DF_Scan}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl ItemsSource="{Binding ScanDirectories}" Margin="0,10,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Chip Content="{Binding}" Margin="0,0,6,6"
                                             IsDeletable="True"
                                             DeleteCommand="{Binding DataContext.RemoveFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                             DeleteCommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Results -->
        <materialDesign:Card Grid.Row="2" Padding="0"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <ListView ItemsSource="{Binding Groups}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Expander IsExpanded="{Binding IsExpanded}" Margin="0,4">
                                <Expander.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentDuplicate"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"
                                                                     Foreground="{DynamicResource MaterialDesign.Brush.Secondary}" />
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Count, Mode=OneWay}" FontWeight="Bold" />
                                                <Run Text="{Binding [DF_IdenticalFiles], Source={x:Static lang:LangProvider.Instance}, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                            <Run Text="{Binding [DF_Each], Source={x:Static lang:LangProvider.Instance}, Mode=OneWay}" />
                                            <Run Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" FontWeight="Bold" />
                                        </TextBlock>

                                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                                   FontWeight="Bold">
                                            <Run Text="{Binding [DF_CanFree], Source={x:Static lang:LangProvider.Instance}, Mode=OneWay}" />
                                            <Run Text="{Binding WastedSpace, Converter={StaticResource FileSizeConverter}, Mode=OneWay}" />
                                        </TextBlock>
                                    </Grid>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding Files}" Margin="32,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}" FontWeight="Medium" />
                                                    <TextBlock Text="{Binding Directory}" Opacity="0.5" FontSize="11"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding LastModified, StringFormat=yyyy-MM-dd}"
                                                           VerticalAlignment="Center" Opacity="0.6" Margin="8,0" FontSize="12" />

                                                <Button Grid.Column="3" ToolTip="{lang:Lang DF_OpenInExplorer}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Scanning Overlay -->
                <Border Background="#80000000"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                                     Width="300" Margin="0,0,0,12" />
                        <TextBlock Text="{Binding CurrentScanPath}" Foreground="#AAFFFFFF"
                                   HorizontalAlignment="Center" FontSize="11"
                                   TextTrimming="CharacterEllipsis" MaxWidth="400" Margin="0,4,0,8" />
                        <Button Content="{lang:Lang DF_Cancel}" Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="White" BorderBrush="White"
                                Width="120" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- Status -->
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" Margin="0,8,0,4" FontSize="13" />

        <!-- Actions -->
        <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="12,8"
                                 Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                 Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{lang:Lang DF_Freeable}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding WastedSpaceText}" FontWeight="Bold" FontSize="16"
                               VerticalAlignment="Center" />
                </StackPanel>
            </materialDesign:Card>

            <Button Grid.Column="2" Content="{lang:Lang DF_AutoSelect}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding AutoSelectDuplicatesCommand}"
                    Margin="8,0" />

            <Button Grid.Column="3" Content="{lang:Lang DF_DeleteSelected}"
                    Style="{StaticResource DangerRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="4"
                    Click="DeleteSelected_Click"
                    Padding="24,8" />
        </Grid>
    </Grid>
</UserControl>
